    public function external_system_settings()
    {
        if (!has_permission('external_products', '', 'view')) {
            access_denied('external_products View');
        }
        close_setup_menu();

        $activeTab = $this->input->get('tab');
        if (empty($activeTab)) {
            $activeTab = 'haravan';
        }

        if ($this->input->post()) {
            $system   = $this->input->post('system');
            $settings = (array) $this->input->post('settings');

            $result     = false;
            $messageKey = 'external_system_settings_update_failed';

            switch ($system) {
                case 'haravan':
                    $result     = $this->external_products_model->update_haravan_api_settings($settings);
                    $messageKey = 'haravan_settings_updated_successfully';
                    break;
                case 'woocommerce':
                    $result     = $this->external_products_model->update_woocommerce_settings($settings);
                    $messageKey = 'woocommerce_settings_updated_successfully';
                    break;
                case 'shopify':
                    $result     = $this->external_products_model->update_shopify_settings($settings);
                    $messageKey = 'shopify_settings_updated_successfully';
                    break;
                case 'magento':
                    $result     = $this->external_products_model->update_magento_settings($settings);
                    $messageKey = 'magento_settings_updated_successfully';
                    break;
            }

            if ($result) {
                set_alert('success', _l($messageKey));
            } else {
                set_alert('danger', _l('external_system_settings_update_failed'));
            }

            redirect(admin_url('external_products/external_system_settings?tab=' . $system));
        }

        $data['title']        = _l('external_systems_configuration');
        $data['active_tab']   = $activeTab;
        $data['available_skus'] = $this->external_products_model->get_available_haravan_sync_skus();
        $data['haravan']      = [
            'enabled'  => get_option('haravan_api_enabled'),
            'token'    => get_option('haravan_api_token'),
            'base_url' => get_option('haravan_api_base_url'),
        ];
        $data['woocommerce']  = [
            'api_url' => get_option('woocommerce_api_url'),
            'api_key' => get_option('woocommerce_api_key'),
        ];
        $data['shopify']      = [
            'api_url'      => get_option('shopify_api_url'),
            'access_token' => get_option('shopify_access_token'),
        ];
        $data['magento']      = [
            'api_url'      => get_option('magento_api_url'),
            'access_token' => get_option('magento_access_token'),
        ];

        $this->load->view('admin/external_system_settings', $data);
    }

