    public function get_haravan_products_data()
    {
        if ($this->input->is_ajax_request()) {
            $products = $this->external_products_model->get_haravan_products();
            $data = [];
            
            foreach ($products as $product) {
                $row = [];
                $row[] = '<div class="checkbox"><input type="checkbox" value="' . $product['id'] . '"><label></label></div>';
                $row[] = $product['id'];
                $row[] = $product['external_product_id'];
                $row[] = $product['external_product_name'];
                $row[] = $product['external_product_sku'];
                $row[] = format_money($product['external_product_price'], 'VND');
                $row[] = $product['external_brand'];
                $row[] = $product['external_category'];
                $row[] = $product['external_stock_quantity'];
                $row[] = _d($product['last_import_date']);
                $row[] = '<div class="row-options">
                    <a href="' . admin_url('external_products/sync_haravan_product/' . $product['external_product_sku']) . '" class="text-info" title="Sync from Haravan">
                        <i class="fa fa-refresh"></i>
                    </a>
                    <a href="' . admin_url('external_products/delete_haravan_product/' . $product['id']) . '" class="text-danger _delete">
                        <i class="fa fa-remove"></i>
                    </a>
                </div>';
                $data[] = $row;
            }
            
            echo json_encode(['data' => $data]);
        }
    }

    public function sync_haravan_product($sku = null)
    {
        if (!has_permission('external_products', '', 'edit')) {
            access_denied('external_products Edit');
        }

        if ($this->input->post()) {
            $sku = $this->input->post('sku');
        }

        if (empty($sku)) {
            echo json_encode([
                'success' => false,
                'message' => 'SKU is required'
            ]);
            return;
        }

        $result = $this->external_products_model->sync_haravan_product_by_sku($sku);
        
        if ($result['success']) {
            echo json_encode([
                'success' => true,
                'message' => $result['message']
            ]);
        } else {
            echo json_encode([
                'success' => false,
                'message' => $result['message']
            ]);
        }
    }

    public function delete_haravan_product($id)
    {
        if (!has_permission('external_products', '', 'delete')) {
            access_denied('external_products Delete');
        }

        $success = $this->external_products_model->delete_external_product($id);
