    public function get_duplicate_details()
    {
        if (!has_permission('external_products', '', 'view')) {
            ajax_access_denied();
        }

        if (! $this->input->is_ajax_request()) {
            show_404();
        }

        $type       = $this->input->get('type');
        $identifier = $this->input->get('identifier');

        switch ($type) {
            case 'sku':
                $this->db->where('sku', $identifier);
                break;
            case 'mapping_id':
            case 'mapping_conflict':
                $mapping_type = $this->input->get('mapping_type');
                $this->db->where('mapping_id', $identifier);
                $this->db->where('mapping_type', $mapping_type);
                break;
            case 'sku_conflict':
                $mapping_type = $this->input->get('mapping_type');
                $this->db->where('sku', $identifier);
                $this->db->where('mapping_type', $mapping_type);
                break;
            default:
                echo json_encode(['data' => []]);
                return;
        }

        $records = $this->db->get(db_prefix() . 'external_products_mapping')->result_array();

        $data = [];
        foreach ($records as $record) {
            $row   = [];
            $row[] = '<div class="checkbox"><input type="checkbox" value="' . $record['id'] . '" class="duplicate-checkbox"><label></label></div>';
            $row[] = $record['id'];
            $row[] = $record['sku'];
            $row[] = $record['mapping_id'];
            $row[] = '<span class="mapping-type-badge ' . $record['mapping_type'] . '">' . format_mapping_type($record['mapping_type']) . '</span>';
            $row[] = '<button class="btn btn-sm btn-success keep-record" data-id="' . $record['id'] . '">' . _l('keep_this') . '</button>';
            $data[] = $row;
        }

        echo json_encode(['data' => $data]);
    }

