            echo json_encode([
                'success' => false,
                'message' => _l('no_items_selected')
            ]);
            return;
        }

        if ($action === 'clear_data') {
            $updated = $this->external_products_model->bulk_clear_order_mapping_data($ids);
        } elseif ($action === 'set_mapping_status') {
            if ($status === '') {
                echo json_encode([
                    'success' => false,
                    'message' => 'Missing mapping status'
                ]);
                return;
            }
            $updated = $this->external_products_model->bulk_update_order_mapping_status($ids, $status);
        } else {
            echo json_encode([
                'success' => false,
                'message' => 'Invalid action'
            ]);
            return;
        }

        echo json_encode([
            'success' => $updated > 0,
            'message' => $updated > 0 ? 'Updated ' . $updated . ' record(s)' : 'No records updated'
        ]);
    }

