    public function add_mapping()
    {
        if (!has_permission('external_products', '', 'create')) {
            access_denied('external_products Create');
        }

        if ($this->input->post()) {
            $this->form_validation->set_rules('sku', 'SKU', 'required');
            $this->form_validation->set_rules('mapping_id', 'Mapping ID', 'required');
            $this->form_validation->set_rules('mapping_type', 'Mapping Type', 'required');

            if ($this->form_validation->run() == false) {
                echo json_encode([
                    'success' => false,
                    'message' => validation_errors()
                ]);
            } else {
                $data = $this->input->post();
                
                // Check if mapping already exists
                $existing = $this->external_products_model->get_external_product_mapping_by_mapping_id($data['mapping_id'], $data['mapping_type']);
                if ($existing) {
                    echo json_encode([
                        'success' => false,
                        'message' => _l('mapping_already_exists')
                    ]);
                    return;
                }

                $insert_id = $this->external_products_model->add_external_product_mapping($data);
                if ($insert_id) {
                    echo json_encode([
                        'success' => true,
                        'message' => _l('external_product_added_successfully')
                    ]);
                } else {
                    echo json_encode([
                        'success' => false,
                        'message' => 'Failed to add mapping'
                    ]);
                }
            }
        } else {
            $data['title'] = _l('add_external_product');
            $data['products'] = $this->products_model->get_by_id_product();
            $this->load->view('admin/add_mapping', $data);
        }
    }

    public function edit_mapping($id)
    {
        if (!has_permission('external_products', '', 'edit')) {
            access_denied('external_products Edit');
        }

        $mapping = $this->external_products_model->get_external_product_mapping($id);
        if (!$mapping) {
            show_404();
        }

        if ($this->input->post()) {
            $this->form_validation->set_rules('sku', 'SKU', 'required');
            $this->form_validation->set_rules('mapping_id', 'Mapping ID', 'required');
            $this->form_validation->set_rules('mapping_type', 'Mapping Type', 'required');

            if ($this->form_validation->run() == false) {
                echo json_encode([
                    'success' => false,
                    'message' => validation_errors()
                ]);
            } else {
                $data = $this->input->post();
                
                // Check if mapping already exists (excluding current record)
                $existing = $this->external_products_model->get_external_product_mapping_by_mapping_id($data['mapping_id'], $data['mapping_type']);
                if ($existing && $existing->id != $id) {
                    echo json_encode([
                        'success' => false,
                        'message' => _l('mapping_already_exists')
                    ]);
                    return;
                }

                $success = $this->external_products_model->update_external_product_mapping($data, $id);
                if ($success) {
                    echo json_encode([
                        'success' => true,
                        'message' => _l('external_product_updated_successfully')
                    ]);
                } else {
                    echo json_encode([
                        'success' => false,
                        'message' => 'Failed to update mapping'
                    ]);
                }
            }
        } else {
            $data['title'] = _l('edit_external_product');
            $data['mapping'] = $mapping;
            $data['products'] = $this->products_model->get_by_id_product();
            $this->load->view('admin/edit_mapping', $data);
        }
    }

    public function delete_mapping($id)
    {
        if (!has_permission('external_products', '', 'delete')) {
            access_denied('external_products Delete');
        }

        $success = $this->external_products_model->delete_external_product_mapping($id);
        if ($success) {
