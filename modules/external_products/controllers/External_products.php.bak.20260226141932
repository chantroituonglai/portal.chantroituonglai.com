    public function sync_orders()
    {
        if (!has_permission('external_products', '', 'edit')) {
            access_denied('external_products Edit');
        }

        $system = $this->input->post('system');
        if (empty($system)) {
            echo json_encode([
                'success' => false,
                'message' => 'Please select a system to sync'
            ]);
            return;
        }

        // Get external system configuration
        $external_system = $this->external_products_model->get_external_system_by_name($system);
        if (!$external_system) {
            echo json_encode([
                'success' => false,
                'message' => 'External system not found'
            ]);
            return;
        }

        // Sync orders from external system
        $result = $this->external_products_model->sync_orders_from_external_system($external_system);
        
        if ($result['success']) {
            echo json_encode([
                'success' => true,
                'message' => 'Orders synced successfully. ' . $result['count'] . ' orders processed.'
            ]);
        } else {
            echo json_encode([
                'success' => false,
                'message' => 'Failed to sync orders: ' . $result['message']
            ]);
        }
    }

